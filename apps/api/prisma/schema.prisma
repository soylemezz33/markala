// Markala — Prisma şeması
// Database: PostgreSQL
// Migrations: pnpm --filter @markala/api prisma:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Kullanıcılar ===

enum AccountType {
  individual
  corporate
}

enum UserRole {
  customer
  admin
  super_admin
}

enum CorporateStatus {
  none
  pending
  approved
  rejected
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  fullName     String      @map("full_name")
  phone        String?
  accountType  AccountType @default(individual) @map("account_type")
  role         UserRole    @default(customer)

  // Kurumsal alanlar (B2B)
  companyName          String?         @map("company_name")
  taxOffice            String?         @map("tax_office")
  taxNumber            String?         @map("tax_number")
  corporateStatus      CorporateStatus @default(none) @map("corporate_status")
  corporateApprovedAt  DateTime?       @map("corporate_approved_at")
  corporateDiscount    Decimal?        @map("corporate_discount") @db.Decimal(5, 2)
  corporateCreditLimit Decimal?        @map("corporate_credit_limit") @db.Decimal(12, 2)
  corporatePaymentTermDays Int?        @map("corporate_payment_term_days")

  // 2FA — secret artık AES-256-GCM ile şifreli saklanır (EncryptionService).
  // DB kolonu mevcut secret'a göre yeniden adlandırıldı: two_factor_secret_encrypted.
  twoFactorEnabled           Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret            String?  @map("two_factor_secret_encrypted")
  // Backup kodları artık bcrypt ile hash'lenmiş tutulur (string array yerine kodun kendisi DB'de aranabilir değildir).
  twoFactorBackupCodesHashed String[] @default([]) @map("two_factor_backup_codes_hashed")

  // KVKK — pazarlama izni (açık rıza)
  marketingConsent       Boolean   @default(false) @map("marketing_consent")
  marketingConsentAt     DateTime? @map("marketing_consent_at")
  marketingConsentSource String?   @map("marketing_consent_source")

  // Duyuru tercihleri: { [typeId]: { email: bool, sms: bool } } — müşteri "Bildirim Tercihleri" ekranı.
  notificationPrefs Json? @map("notification_prefs")

  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  addresses             Address[]
  orders                Order[]
  designUploads         DesignUpload[]
  corporateApplications CorporateApplication[]
  ledgerEntries         CorporateLedgerEntry[]
  corporatePayments     CorporatePayment[]
  monthlyInvoices       CorporateMonthlyInvoice[]
  refreshTokens              RefreshToken[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  notifications              NotificationLog[]
  consentLogs                ConsentLog[]

  @@index([role])
  @@index([corporateStatus])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Birinci-parti ziyaretçi/davranış olayları — admin ziyaretçi analizi & CRM panelini besler.
/// userId opsiyonel plain string (FK YOK): olaylar kullanıcı silinse de korunur, cascade maliyeti yok.
model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String   // page_view | product_view | add_to_cart | begin_checkout | purchase | search | session_start
  sessionId   String   @map("session_id") // anonim ziyaretçi oturumu (cookie/localStorage uuid)
  userId      String?  @map("user_id") // giriş yapmışsa
  path        String?
  productSlug String?  @map("product_slug")
  dwellMs     Int?     @map("dwell_ms") // ürün inceleme süresi (ms)
  value       Decimal? @db.Decimal(12, 2) // sepet/sipariş tutarı (add_to_cart/purchase)
  referrer    String?
  device      String?  // mobile | desktop | tablet
  utmSource   String?  @map("utm_source")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([productSlug, type])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("analytics_events")
}

model CorporateApplication {
  id     String  @id @default(cuid())
  userId String? @map("user_id")

  companyName  String  @map("company_name")
  taxOffice    String  @map("tax_office")
  taxNumber    String  @map("tax_number")
  sector       String?
  annualVolume String? @map("annual_volume")

  contactName String  @map("contact_name")
  contactRole String? @map("contact_role")
  email       String
  phone       String
  address     String  @db.Text
  notes       String? @db.Text

  taxCertificateUrl    String? @map("tax_certificate_url")
  signatureCircularUrl String? @map("signature_circular_url")

  status       CorporateStatus @default(pending)
  reviewedById String?         @map("reviewed_by_id")
  reviewedAt   DateTime?       @map("reviewed_at")
  reviewNote   String?         @map("review_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email])
  @@index([userId])
  @@map("corporate_applications")
}

// Cari hesap (açık hesap) defteri — kurumsal müşteri borç (debit) / ödeme (credit) hareketleri.
enum LedgerEntryKind {
  debit
  credit
}

model CorporateLedgerEntry {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  orderId     String?         @map("order_id")
  kind        LedgerEntryKind
  amount      Decimal         @db.Decimal(12, 2)
  description String
  dueDate     DateTime?       @map("due_date")
  createdAt   DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("corporate_ledger_entries")
}

/// Müşterinin panelinden online (iyzico) yaptığı cari hesap ödemesi (tahsilat).
/// Başarılı callback'te bir CorporateLedgerEntry(credit) oluşturulup bakiye düşürülür.
/// status: pending (iyzico'ya yönlendirildi) | paid (tahsil edildi) | failed.
model CorporatePayment {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  amount          Decimal   @db.Decimal(12, 2)
  status          String    @default("pending")
  iyzicoToken     String?   @map("iyzico_token")
  iyzicoPaymentId String?   @map("iyzico_payment_id")
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  paidAt          DateTime? @map("paid_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("corporate_payments")
}

/// Cari hesap (B2B açık hesap) AYLIK toplu faturası — Faz 3 otomatik aylık faturalama.
/// (userId, period) benzersiz → aynı müşteri/ay ikinci kez faturalanmaz (idempotent).
/// status: pending (kayıt açıldı) | issued (Paraşüt faturası kesildi) | failed | skipped (Paraşüt yapılandırılmamış).
model CorporateMonthlyInvoice {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  /// Faturalanan ay "YYYY-MM" (örn. "2026-05").
  period           String
  /// O aydaki açık-hesap siparişlerinin KDV dahil toplamı.
  totalAmount      Decimal   @map("total_amount") @db.Decimal(12, 2)
  orderCount       Int       @map("order_count")
  status           String    @default("pending")
  parasutInvoiceId String?   @map("parasut_invoice_id")
  issuedAt         DateTime? @map("issued_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([period])
  @@map("corporate_monthly_invoices")
}

model Address {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  label       String
  fullName    String  @map("full_name")
  phone       String
  city        String
  district    String
  fullAddress String  @map("full_address")
  zipCode     String? @map("zip_code")
  isDefault   Boolean @default(false) @map("is_default")

  // Fatura için adres tipi: "individual" (bireysel) | "corporate" (kurumsal).
  // Kurumsal adreslerde companyName + taxNumber zorunlu (DTO katmanında).
  type        String  @default("individual")
  companyName String? @map("company_name")
  taxOffice   String? @map("tax_office")
  taxNumber   String? @map("tax_number")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@map("addresses")
}

// === Katalog ===

model Category {
  id               String  @id @default(cuid())
  slug             String  @unique
  name             String
  shortDescription String  @map("short_description")
  longDescription  String  @map("long_description")
  imageUrl         String  @map("image_url")
  accentColor      String? @map("accent_color")
  startingPrice    Decimal @map("starting_price") @db.Decimal(10, 2)
  productionTime   String  @map("production_time")
  sortOrder        Int     @default(0) @map("sort_order")
  isActive         Boolean @default(true) @map("is_active")
  content          Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  categoryId       String   @map("category_id")
  shortDescription String   @map("short_description")
  description      String   @db.Text
  basePrice        Decimal  @map("base_price") @db.Decimal(10, 2)
  startingPrice    Decimal? @map("starting_price") @db.Decimal(10, 2)
  productionTime   String   @map("production_time")
  sizeLabel        String?  @map("size_label")
  images           String[]
  badges           String[] @default([])
  bestseller       Boolean  @default(false)
  ratingAverage    Decimal? @map("rating_average") @db.Decimal(3, 2)
  ratingCount      Int      @default(0) @map("rating_count")
  isActive         Boolean  @default(true) @map("is_active")
  /// Konfigüratör parametreleri JSON: { id, label, kind, options, ... }
  parameters       Json     @default("[]")
  /// SEO/içerik JSON: { features, useCases, specifications, faqs, relatedSlugs, seo, brand, sku, rating }
  /// Storefront ürün sayfası bu zengin içeriği gösterir — API canonical kaynak olsun, SEO regresyonu olmasın.
  content          Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category   Category       @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]
  prices     ProductPrice[]
  options    ProductOption[]

  @@index([categoryId, isActive])
  @@index([bestseller, isActive])
  @@map("products")
}

// === Sipariş ===

enum OrderStatus {
  siparis_alindi     @map("siparis-alindi")
  tasarim_bekleniyor @map("tasarim-bekleniyor")
  tasarim_onayindi   @map("tasarim-onayindi")
  uretimde
  kargoya_verildi    @map("kargoya-verildi")
  teslim_edildi      @map("teslim-edildi")
  iptal_edildi       @map("iptal-edildi")
}

enum PaymentStatus {
  beklemede
  basarili
  basarisiz
  iade_edildi @map("iade-edildi")
}

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique @map("order_number")
  userId      String? @map("user_id")
  email       String
  phone       String

  status        OrderStatus   @default(siparis_alindi)
  paymentStatus PaymentStatus @default(beklemede) @map("payment_status")
  // Ödeme yolu: null/"iyzico" (online), "cari" (açık hesap/B2B), "havale" vb.
  paymentMethod String?       @map("payment_method")

  // Kuruş hassasiyeti için (12, 4); ara toplam/KDV/toplam yuvarlama hatasını azaltır.
  subtotal    Decimal @db.Decimal(12, 4)
  shippingFee Decimal @map("shipping_fee") @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  vat         Decimal @db.Decimal(12, 4)
  total       Decimal @db.Decimal(12, 4)

  // Kayıtlı müşteri (hesabım > adreslerim) siparişlerinde FK doldurulur.
  // Storefront/misafir siparişlerinde adres kaydı yoktur (kullanıcı checkout'ta
  // satır-içi girer) — bu yüzden FK opsiyoneldir; adres aşağıdaki snapshot'ta tutulur.
  shippingAddressId String? @map("shipping_address_id")
  billingAddressId  String? @map("billing_address_id")

  // Satır-içi (misafir/storefront) adres snapshot'ı — FK yoksa kullanılır.
  // { fullName, phone, city, district, fullAddress, zipCode?, label? }
  shippingAddressSnapshot Json? @map("shipping_address_snapshot")
  billingAddressSnapshot  Json? @map("billing_address_snapshot")

  // iyzico referansları
  iyzicoPaymentId      String? @map("iyzico_payment_id")
  iyzicoConversationId String? @map("iyzico_conversation_id")

  // Kargo takibi
  trackingNumber  String?   @map("tracking_number")
  trackingCarrier String?   @map("tracking_carrier")
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")

  // iyzico checkout form token (init'te saklanır) — callback kaçarsa reconciliation bununla
  // ödemeyi retrieve edip siparişi kurtarır ("para çekildi ama işaretlenmedi" güvenlik ağı).
  iyzicoCheckoutToken String? @map("iyzico_checkout_token")

  // Paraşüt e-fatura
  parasutInvoiceId String? @map("parasut_invoice_id")

  notes String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  // KVKK & Türk Ticaret Kanunu — mali kayıt 10 yıl saklanır; soft delete.
  deletedAt DateTime? @map("deleted_at")

  user            User?          @relation(fields: [userId], references: [id])
  shippingAddress Address?       @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?       @relation("BillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  designUploads   DesignUpload[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([iyzicoConversationId])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  // Kampanya paketi (CampaignPackage — Product değil) kalemlerinde null; normal üründe dolu.
  productId String? @map("product_id")

  productSlug          String  @map("product_slug")
  productName          String  @map("product_name")
  productImage         String  @map("product_image")
  configurationSummary String  @map("configuration_summary")
  /// Konfigüratör seçimleri (snapshot)
  configuration        Json
  unitPrice            Decimal @map("unit_price") @db.Decimal(10, 2)
  quantity             Int
  lineTotal            Decimal @map("line_total") @db.Decimal(10, 2)

  needsDesignSupport Boolean @default(false) @map("needs_design_support")
  uploadedFileName   String? @map("uploaded_file_name")
  uploadedFileUrl    String? @map("uploaded_file_url")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// === Tasarım yüklemeleri (R2 storage) ===

model DesignUpload {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  orderId   String?  @map("order_id")
  fileName  String   @map("file_name")
  fileSize  Int      @map("file_size")
  fileUrl   String   @map("file_url")
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
  @@map("design_uploads")
}

// === Kuponlar ===

enum CouponType {
  percentage
  fixed_amount  @map("fixed-amount")
  free_shipping @map("free-shipping")
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(10, 2)
  minOrderAmount Decimal?   @map("min_order_amount") @db.Decimal(10, 2)
  maxUses        Int?       @map("max_uses")
  usedCount      Int        @default(0) @map("used_count")
  validFrom      DateTime?  @map("valid_from")
  validUntil     DateTime?  @map("valid_until")
  isActive       Boolean    @default(true) @map("is_active")
  /// true ise kupon YALNIZCA müşterinin İLK siparişinde geçerli (HOSGELDIN gibi). Önceki siparişi
  /// olan kullanıcı/e-posta reddedilir. Tekrar kullanımı engeller.
  firstOrderOnly Boolean    @default(false) @map("first_order_only")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code, isActive])
  @@map("coupons")
}

// === Yorumlar ===

model Review {
  id          String  @id @default(cuid())
  productId   String  @map("product_id")
  orderItemId String? @unique @map("order_item_id")
  userName    String  @map("user_name")
  userCompany String? @map("user_company")
  rating      Int
  comment     String  @db.Text
  isApproved  Boolean @default(false) @map("is_approved")

  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isApproved, createdAt])
  @@map("reviews")
}

// === Blog ===

enum BlogStatus {
  draft
  published
  archived
}

model BlogCategory {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String? @db.Text
  sortOrder   Int     @default(0) @map("sort_order")

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id         String     @id @default(cuid())
  slug       String     @unique
  title      String
  excerpt    String     @db.Text
  content    String     @db.Text
  coverImage String?    @map("cover_image")
  authorName String     @map("author_name")
  authorRole String?    @map("author_role")
  categoryId String?    @map("category_id")
  tags       String[]   @default([])
  status     BlogStatus @default(draft)

  // SEO
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")
  ogImage        String? @map("og_image")

  readingTime Int? @map("reading_time")
  viewCount   Int  @default(0) @map("view_count")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@map("blog_posts")
}

// === A/B Testing ===

model AbTest {
  id          String    @id @default(cuid())
  testKey     String    @unique @map("test_key")
  name        String
  description String?   @db.Text
  variants    Json // [{ id: "A", weight: 50 }, { id: "B", weight: 50 }]
  isActive    Boolean   @default(true) @map("is_active")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")

  events AbTestEvent[]

  @@map("ab_tests")
}

model AbTestEvent {
  id        String  @id @default(cuid())
  testId    String  @map("test_id")
  variant   String
  eventType String  @map("event_type") // exposure | conversion
  eventName String? @map("event_name")
  userId    String? @map("user_id")
  uid       String // anonymous cookie ID
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  test AbTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, eventType, createdAt])
  @@index([uid])
  @@map("ab_test_events")
}

// === Bildirimler ===

enum NotificationChannel {
  email
  sms
  push
}

model NotificationLog {
  id        String              @id @default(cuid())
  userId    String?             @map("user_id")
  channel   NotificationChannel
  template  String // Örn: "order-shipped", "corporate-approved"
  recipient String // email veya telefon
  subject   String?
  body      String              @db.Text
  status    String // sent | failed | bounced
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([template, status])
  @@map("notification_logs")
}

/// İletişim formu mesajları — SMTP'den BAĞIMSIZ kalıcı kayıt (mail gitmese bile lead kaybolmaz).
/// Admin "Gelen Kutusu"ndan görüntülenir; corporate_applications ile aynı DB-first deseni.
model ContactMessage {
  id        String   @id @default(cuid())
  ticketId  String   @unique @map("ticket_id")
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  source    String   @default("iletisim") // iletisim | teklif | ...
  status    String   @default("new") // new | read | archived
  mailSent  Boolean  @default(false) @map("mail_sent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

/// Teklif talepleri (/teklif-al) — işletme + sektör + çoğunlukla kullanılan ürünler (çoktan-seçmeli).
/// ContactMessage ile aynı DB-first deseni; admin "Teklif Talepleri" gelen kutusundan yönetilir.
model QuoteRequest {
  id          String   @id @default(cuid())
  ticketId    String   @unique @map("ticket_id")
  name        String
  email       String
  phone       String
  companyName String?  @map("company_name")
  sector      String?
  products    String[] @default([]) // seçilen ürün etiketleri (+ "Diğer" serbest metin dahil)
  budget      String?  // tahmini bütçe aralığı (opsiyonel)
  quantity    String?  // tahmini adet/sıklık (opsiyonel)
  message     String?  @db.Text
  source      String   @default("teklif-al")
  status      String   @default("new") // new | contacted | quoted | closed
  mailSent    Boolean  @default(false) @map("mail_sent")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("quote_requests")
}

/// Bülten aboneleri — SMTP'den BAĞIMSIZ kalıcı liste (signup kaybolmaz). E-posta benzersiz → idempotent.
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("web") // blog-newsletter | footer | ...
  status    String   @default("active") // active | unsubscribed
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("newsletter_subscribers")
}

// === KVKK — Rıza & Audit kayıtları ===

/// Açık rıza kayıtları — KVKK uyum için tüm onaylar (kayıt, pazarlama, çerez)
/// burada zaman damgalı, IP/UA'lı saklanır. İspat yükümlülüğü için silinmez.
model ConsentLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  email       String?
  consentType String   @map("consent_type") // 'kvkk' | 'marketing' | 'cookies-analytics' | 'cookies-marketing'
  granted     Boolean
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  version     String? // policy version
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([consentType, createdAt])
  @@map("consent_logs")
}

/// Hassas varlık değişiklikleri (kullanıcı, sipariş, ürün) için tam izleme.
/// KVKK 12. madde "veri güvenliği" ve admin işlemlerinin denetlenebilirliği için.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  actorId    String?  @map("actor_id") // admin yapıyorsa
  entityType String   @map("entity_type") // 'User', 'Order', 'Product'
  entityId   String   @map("entity_id")
  action     String // 'create', 'update', 'delete', 'status_change'
  diff       Json? // before/after
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

// === Anasayfa slider ===
model HeroSlide {
  id             String   @id @default(cuid())
  title          String
  subtitle       String?
  imageUrl       String   @map("image_url")
  mobileImageUrl String?  @map("mobile_image_url")
  ctaLabel       String?  @map("cta_label")
  ctaHref        String?  @map("cta_href")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("hero_slides")
}

// === Site ayarları (key-value) ===
model SiteSetting {
  key       String   @id
  value     Json
  group     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("site_settings")
}

// === Faz 2: Banner yönetimi ===
model Banner {
  id             String    @id @default(cuid())
  title          String
  location       String // hero | category | cart | footer
  imageUrl       String    @map("image_url")
  mobileImageUrl String?   @map("mobile_image_url")
  ctaLabel       String?   @map("cta_label")
  ctaHref        String?   @map("cta_href")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  clickCount     Int       @default(0) @map("click_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([location, isActive])
  @@map("banners")
}

// === Faz 2: SSS (FAQ) ===
model Faq {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  category    String // tasarim | urun | kargo | odeme | iade | genel
  productSlug String?  @map("product_slug")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category, isActive, sortOrder])
  @@map("faqs")
}

// === Faz 2: Yasal sayfalar ===
model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  version   String   @default("v1.0")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("legal_pages")
}

// === Faz 2: Kampanya paketleri (bundle) ===
model CampaignPackage {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  category      String // esnaf | kurumsal | etkinlik | acilis | promosyon
  contents      String    @db.Text
  listPrice     Decimal   @map("list_price") @db.Decimal(10, 2)
  packagePrice  Decimal   @map("package_price") @db.Decimal(10, 2)
  stockLimit    Int?      @map("stock_limit")
  endDate       DateTime? @map("end_date")
  designSupport Boolean   @default(false) @map("design_support")
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([category, isActive])
  @@map("campaign_packages")
}

// === Markalar / Referanslar (storefront "Referanslar" bölümü) ===
model Brand {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String?  @map("logo_url")
  websiteUrl String?  @map("website_url")
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("brands")
}

// === Fiyat şeması (Task A1) ===

model ProductOption {
  id             String  @id @default(cuid())
  productId      String  @map("product_id")
  groupKey       String  @map("group_key")
  groupLabel     String  @map("group_label")
  groupRole      String  @map("group_role")
  groupSort      Int     @default(0) @map("group_sort")
  optionKey      String  @map("option_key")
  optionLabel    String  @map("option_label")
  optionSublabel String? @map("option_sublabel") @db.Text
  optionSort     Int     @default(0) @map("option_sort")
  locked         Boolean @default(false)
  rules          Json?
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId, groupSort, optionSort])
  @@map("product_options")
}

model ProductPrice {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  groupKey  String?  @map("group_key")
  optionKey String?  @map("option_key")
  dimKey    String?  @map("dim_key")
  cost      Decimal? @db.Decimal(10, 2)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
  @@map("product_prices")
}

