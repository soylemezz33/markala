# Postgres bağlantısı (yerel docker veya prod sunucu)
DATABASE_URL="postgresql://markala:markala@localhost:5432/markala?schema=public"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars-please"
JWT_EXPIRES_IN="7d"

# CORS — frontend origin
WEB_ORIGIN="http://localhost:3000"

# Server
PORT=4000
NODE_ENV="development"

# === FAZ 4'te eklenir ===
# IYZICO_API_KEY=
# IYZICO_SECRET=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# PARASUT_CLIENT_ID=
# PARASUT_CLIENT_SECRET=
# PARASUT_USERNAME=
# PARASUT_PASSWORD=
# PARASUT_COMPANY_ID=
# HEPSIJET_API_KEY=
# SENDGRID_API_KEY=

# Görsel depolama (StorageService).
# API_PUBLIC_URL: local sürücüde dönen mutlak görsel URL tabanı. Boşsa http://localhost:<PORT>.
#   Prod'da API'nin public origin'i (örn. https://api.markala.com.tr).
# API_PUBLIC_URL=
# Aşağıdaki CLOUDFLARE_R2_* tanımlanırsa sürücü otomatik 'r2'ye geçer (yoksa 'local').
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET=
# CLOUDFLARE_R2_BUCKET=markala-uploads
# CLOUDFLARE_R2_PUBLIC_BASE=https://files.markala.com.tr
