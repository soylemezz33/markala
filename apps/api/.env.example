# Postgres bağlantısı (yerel docker veya prod sunucu)
DATABASE_URL="postgresql://markala:markala@localhost:5432/markala?schema=public"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars-please"
JWT_EXPIRES_IN="7d"

# Şifreleme anahtarı — EncryptionService (2FA secret gibi tersine çevrilebilir hassas alanlar için AES-256-GCM).
# Minimum 32 karakter. Üret: openssl rand -base64 48
# ZORUNLU: tanımlı değilse uygulama başlamaz.
ENCRYPTION_KEY="change-me-in-production-min-32-chars-openssl-rand-base64-48"

# CORS — frontend origin
WEB_ORIGIN="http://localhost:3000"

# Server
PORT=4000
NODE_ENV="development"

# === FAZ 4'te eklenir ===
# IYZICO_API_KEY=
# IYZICO_SECRET=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# PARASUT_CLIENT_ID=
# PARASUT_CLIENT_SECRET=
# PARASUT_USERNAME=
# PARASUT_PASSWORD=
# PARASUT_COMPANY_ID=
# HEPSIJET_API_KEY=
# SENDGRID_API_KEY=

# Görsel depolama (StorageService).
# API_PUBLIC_URL: local sürücüde dönen mutlak görsel URL tabanı. Boşsa http://localhost:<PORT>.
#   Prod'da API'nin public origin'i (örn. https://api.markala.com.tr).
# API_PUBLIC_URL=
# Aşağıdaki R2_* tanımlanırsa (R2_ACCESS_KEY_ID) sürücü otomatik 'r2'ye geçer (yoksa 'local').
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=markala-uploads
# R2_PUBLIC_URL=https://uploads.markala.com.tr
