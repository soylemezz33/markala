# ─────────────────────────────────────────────
# Markala Admin — Lokal kurulum için .env.local
# ─────────────────────────────────────────────
#
# 1) Bu dosyayı `.env.local` olarak kopyala
# 2) ADMIN_SESSION_SECRET için 32+ karakter random string üret
#    (PowerShell:  -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | %{[char]$_})  )
# 3) Şifreni hash'lemek için:
#    a. Önce bu dosyada ADMIN_EMAIL ve ADMIN_NAME değerlerini doldur
#    b. Geçici olarak ADMIN_PASSWORD_HASH=placeholder yaz
#    c. `pnpm dev` başlat, http://localhost:3001/api/auth/setup-hash?password=GERCEK_SIFREN aç
#    d. Dönen JSON'daki ADMIN_PASSWORD_HASH değerini buraya yapıştır
#    e. Dev sunucusunu yeniden başlat
#
# Production'da setup-hash endpoint'i otomatik 404 döner.
# ─────────────────────────────────────────────

# Admin kimlik bilgileri (env-based, single user)
ADMIN_EMAIL=hasansylemezz@gmail.com
ADMIN_NAME=Hasan Söylemez
ADMIN_PASSWORD_HASH=

# Cookie imzalama anahtarı — ASLA paylaşma, üretirken yenileme şifre değişimi gerektirmez
ADMIN_SESSION_SECRET=

# Backend API (Postgres bağlandıktan sonra)
NEXT_PUBLIC_API_URL=http://localhost:4000
