# ─────────────────────────────────────────────
# Markala Admin — Lokal kurulum için .env.local
# ─────────────────────────────────────────────
#
# 1) Bu dosyayı `.env.local` olarak kopyala
# 2) ADMIN_SESSION_SECRET için 32+ karakter random string üret
#    (PowerShell:  -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | %{[char]$_})  )
#
# Auth artık BFF: admin kendi şifresini TUTMAZ. Giriş, NestJS API /auth/login'e
# proxy'lenir; yetki admin/super_admin değilse 403. Kullanıcılar API tarafında
# (Postgres users tablosu) yönetilir.
# ─────────────────────────────────────────────

# Cookie imzalama anahtarı (HMAC) — ASLA paylaşma. API JWT'sini taşıyan session'ı imzalar.
ADMIN_SESSION_SECRET=

# Backend API — server-side (BFF) ve tarayıcı için
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
