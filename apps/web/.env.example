# ─────────────────────────────────────────────
# Markala Web — Lokal kurulum için .env.local
# ─────────────────────────────────────────────
# Bu dosyayı `.env.local` olarak kopyala ve ilgili alanları doldur.
# Hiçbiri zorunlu değil — boşsa o özellik devre dışı kalır.
# ─────────────────────────────────────────────

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── E-posta (SMTP) ───
# İletişim formu ve bülten bildirimleri buradan gönderilir.
# SMTP_HOST boş veya "localhost" ise mail gönderimi DEVRE DIŞI kalır (sadece console.log).
# Değerler apps/api (NestJS) ile birebir aynı env adlarını kullanır.
# Üretimde MDaemon SMTP bilgilerini doldurun.
SMTP_HOST=
SMTP_PORT=
# TLS/SSL: 465 portu için "true", 587/25 (STARTTLS) için "false"
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Gönderen adresi, örn: Markala <markala@markala.com.tr>
MAIL_FROM=
# Form ve bülten bildirimlerinin gideceği adres (varsayılan: merhaba@markala.com.tr)
CONTACT_TO=

# ─── Analytics ───
# Google Analytics 4 — analytics.google.com → Mülk → Veri akışı → ölçüm kimliği
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook) Pixel — business.facebook.com → Events Manager → Pixel ID
# KVKK: yalnızca marketing consent verildiğinde event gönderilir (bkz. lib/analytics.ts)
NEXT_PUBLIC_META_PIXEL_ID=

# Microsoft Clarity (ücretsiz ısı haritası) — clarity.microsoft.com → proje → tracking ID
NEXT_PUBLIC_CLARITY_ID=

# Hotjar (opsiyonel, ücretli) — hotjar.com → Site ID
NEXT_PUBLIC_HOTJAR_ID=

# Google Tag Manager (opsiyonel) — tagmanager.google.com → Container ID (GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# ─── Search Engine Verification ───
# Google Search Console → "URL prefix" → "HTML tag" → content="..." değerini buraya
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools → meta tag content değeri
NEXT_PUBLIC_BING_VERIFICATION=

# Yandex Webmaster
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ─── A/B Testing ───
# JSON: aktif test ID listesi (cookie zaten otomatik atanır)
NEXT_PUBLIC_AB_TESTS=
