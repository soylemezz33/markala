{
  "name": "markala",
  "version": "0.1.0",
  "private": true,
  "description": "Markala — matbaa ve reklam ürünleri e-ticaret platformu",
  "scripts": {
    "dev": "pnpm --filter @markala/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": "pnpm --filter @markala/web lint",
    "apps/admin/src/**/*.{ts,tsx}": "pnpm --filter @markala/admin lint",
    "apps/api/src/**/*.ts": "pnpm --filter @markala/api type-check"
  }
}
