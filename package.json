{
  "name": "markala",
  "version": "0.1.0",
  "private": true,
  "description": "Markala — matbaa ve reklam ürünleri e-ticaret platformu",
  "scripts": {
    "dev": "pnpm --filter @markala/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "prettier": "^3.8.4"
  },
  "pnpm": {
    "overrides": {
      "lodash@<4.18.0": ">=4.18.0 <5",
      "multer@<2.2.0": ">=2.2.0 <3",
      "qs@<6.15.2": ">=6.15.2 <7",
      "postcss@<8.5.10": ">=8.5.10 <9",
      "js-yaml@<4.2.0": ">=4.2.0 <5",
      "rollup@>=3.0.0 <3.30.0": ">=3.30.0 <4",
      "webpack@<5.104.1": ">=5.104.1 <6",
      "@babel/core@<7.29.6": ">=7.29.6 <8",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0 <11",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4 <5",
      "tmp@<0.2.6": ">=0.2.6 <0.3",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0 <9",
      "ws@>=7.0.0 <7.5.11": ">=7.5.11 <8",
      "ajv@>=7.0.0 <8.18.0": ">=8.18.0 <9",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6 <5"
    }
  }
}
