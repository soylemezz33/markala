{
  "name": "markala",
  "version": "0.1.0",
  "private": true,
  "description": "Markala — matbaa ve reklam ürünleri e-ticaret platformu",
  "scripts": {
    "dev": "pnpm --filter @markala/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "prettier": "^3.8.4"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.2.0 <3",
      "qs": ">=6.15.2 <7",
      "lodash": ">=4.17.23 <5",
      "form-data": ">=4.0.6 <5",
      "postcss": ">=8.5.10 <9",
      "js-yaml": ">=4.2.0 <5",
      "ajv": ">=8.18.0 <9",
      "picomatch": ">=4.0.4 <5",
      "rollup": ">=3.30.0 <4",
      "webpack": ">=5.104.1 <6",
      "@babel/core": ">=7.29.6 <8",
      "glob": ">=10.5.0 <11",
      "tmp": ">=0.2.6 <0.3"
    }
  }
}
