{
  "name": "markala",
  "version": "0.1.0",
  "private": true,
  "description": "Markala — matbaa ve reklam ürünleri e-ticaret platformu",
  "scripts": {
    "dev": "pnpm --filter @markala/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "prettier": "^3.8.4"
  },
  "pnpm": {
    "overrides": {
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "lodash@>=4.0.0 <4.18.0": ">=4.18.0",
      "multer@>=2.0.0 <2.2.0": ">=2.2.0",
      "tmp@<0.2.6": ">=0.2.6",
      "qs@>=6.11.1 <6.15.2": ">=6.15.2",
      "postcss@<8.5.10": ">=8.5.10",
      "js-yaml@>=4.0.0 <4.2.0": ">=4.2.0"
    }
  }
}
