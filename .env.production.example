# ═════════════════════════════════════════════════════════════════
# Markala — Production Environment Variables
# ═════════════════════════════════════════════════════════════════
# Bu dosyayı `.env.production` olarak kopyala ve gerçek değerlerle doldur.
# .env.production VPS'de /opt/markala/ altında bulunmalı.
# ASLA repoya commit ETME — .gitignore'da bloklu.
#
# Kurulum:
#   ssh markala@VPS_IP
#   cd /opt/markala
#   nano .env.production  # bu dosyayı buraya kopyala
#   chmod 600 .env.production
# ═════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───
POSTGRES_DB=markala
POSTGRES_USER=markala
# Min 32 karakter, alfanumerik + sembol
POSTGRES_PASSWORD=

# ─── JWT (apps/api) ───
# openssl rand -hex 64
JWT_SECRET=

# ─── Admin (apps/admin) ───
# Login için
ADMIN_EMAIL=hasansylemezz@gmail.com
ADMIN_NAME=Hasan Söylemez
# /api/auth/setup-hash?password=XXX endpoint'inden üret (dev'de)
ADMIN_PASSWORD_HASH=
# openssl rand -base64 48
ADMIN_SESSION_SECRET=

# ─── iyzico (Ödeme) ───
# https://iyzico.com → Geliştirici → Production
IYZICO_API_KEY=
IYZICO_SECRET=

# ─── Paraşüt (Muhasebe / e-Fatura) ───
PARASUT_CLIENT_ID=
PARASUT_CLIENT_SECRET=
PARASUT_COMPANY_ID=

# ─── SendGrid (E-posta) ───
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=merhaba@markala.com.tr
SENDGRID_FROM_NAME=Markala

# ─── NetGSM (SMS) ───
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=MARKALA

# ─── DHL Express (Kargo) ───
DHL_API_KEY=
DHL_ACCOUNT_NUMBER=

# ─── Cloudflare R2 (Dosya yükleme) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=markala-uploads
R2_PUBLIC_URL=https://uploads.markala.com.tr

# ─── Analytics (Web — public, image içine bake olur) ───
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ─── Sentry (Error tracking) ───
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ─── AI (Claude / Anthropic) — opsiyonel ───
# Tanımlı DEĞİLSE: AI özellikleri sessizce deterministik şablona düşer (maliyet 0).
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
# Maliyet-odaklı varsayılan: claude-haiku-4-5. Üst kalite için: claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# ─── GitHub Actions Deploy ───
# GitHub repo settings → Secrets:
#   SSH_HOST=<VPS_IP>
#   SSH_USER=markala
#   SSH_PRIVATE_KEY=<deploy private key>
#   SSH_PORT=22

# ─── Image tag (deploy zamanı override) ───
TAG=latest
GITHUB_REPOSITORY=soylemezz33/markala
